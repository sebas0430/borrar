--
-- Name: fn_calcular_tiempos_entrega(integer, timestamp without time zone, timestamp without time zone); Type: FUNCTION; Schema: public; Owner: estudiante
--

CREATE FUNCTION public.fn_calcular_tiempos_entrega(p_mesero_id integer DEFAULT NULL::integer, p_fecha_inicio timestamp without time zone DEFAULT NULL::timestamp without time zone, p_fecha_fin timestamp without time zone DEFAULT NULL::timestamp without time zone) RETURNS TABLE(mesero_id integer, mesero_nombre text, pedidos_atendidos bigint, tiempo_promedio_entrega interval, eficiencia numeric)
    LANGUAGE plpgsql
    AS $$
BEGIN
    RETURN QUERY
    SELECT 
        USR.id AS mesero_id,
        USR.nombre AS mesero_nombre,
        COUNT(DISTINCT PED.id) AS pedidos_atendidos,
        AVG(ORD.entregado - PED.solicitado) AS tiempo_promedio_entrega,
        ROUND(COUNT(DISTINCT CASE WHEN ORD.entregado - PED.solicitado < '00:30:00' THEN PED.id END) * 100.0 / 
              NULLIF(COUNT(DISTINCT PED.id), 0), 2) AS eficiencia
    FROM 
        pedidos AS PED
    JOIN 
        usuarios AS USR ON PED.mesero_id = USR.id
    JOIN 
        ordenes AS ORD ON PED.id = ORD.pedido_id
    WHERE 
        (p_mesero_id IS NULL OR PED.mesero_id = p_mesero_id)
        AND (p_fecha_inicio IS NULL OR PED.solicitado >= p_fecha_inicio)
        AND (p_fecha_fin IS NULL OR PED.solicitado <= p_fecha_fin)
        AND ORD.entregado IS NOT NULL
    GROUP BY 
        USR.id, USR.nombre
    ORDER BY 
        tiempo_promedio_entrega;
END;
$$;


ALTER FUNCTION public.fn_calcular_tiempos_entrega(p_mesero_id integer, p_fecha_inicio timestamp without time zone, p_fecha_fin timestamp without time zone) OWNER TO "estudiante";

--
-- Name: fn_obtener_ordenes_filtradas(integer, integer, integer); Type: FUNCTION; Schema: public; Owner: estudiante
--

CREATE FUNCTION public.fn_obtener_ordenes_filtradas(p_cliente_id integer, p_plato_id integer, p_cantidad_min integer) RETURNS TABLE(orden_id integer, pedido_id integer, nombre_plato text, cantidad integer, precio_unitario numeric, subtotal numeric, estado_orden public.estadoorden, fecha_solicitud timestamp with time zone, fecha_entrega timestamp with time zone)
    LANGUAGE plpgsql
    AS $$
BEGIN
    -- Validar existencia del cliente
    IF NOT EXISTS (SELECT 1 FROM usuarios WHERE id = p_cliente_id) THEN
        RAISE EXCEPTION 'El cliente con ID % no existe', p_cliente_id;
    END IF;
    
    -- Validar existencia del plato
    IF NOT EXISTS (SELECT 1 FROM platos WHERE id = p_plato_id) THEN
        RAISE EXCEPTION 'El plato con ID % no existe', p_plato_id;
    END IF;
    
    -- Validar cantidad mínima
    IF p_cantidad_min <= 0 THEN
        RAISE EXCEPTION 'La cantidad mínima debe ser mayor que cero';
    END IF;

    RETURN QUERY
    SELECT 
        ORD.id AS orden_id,
        ORD.pedido_id,
        PLA.nombre AS nombre_plato,
        ORD.cantidad,
        PLA.precio AS precio_unitario,
        (ORD.cantidad * PLA.precio) AS subtotal,
        ORD.estado AS estado_orden,
        PED.solicitado AS fecha_solicitud,
        ORD.entregado AS fecha_entrega
    FROM 
        ordenes AS ORD
    JOIN 
        platos AS PLA ON ORD.plato_id = PLA.id
    JOIN 
        pedidos AS PED ON ORD.pedido_id = PED.id
    WHERE 
        PED.cliente_id = p_cliente_id
        AND PLA.id = p_plato_id
        AND ORD.cantidad >= p_cantidad_min
    ORDER BY 
        PED.solicitado DESC;
END;
$$;


ALTER FUNCTION public.fn_obtener_ordenes_filtradas(p_cliente_id integer, p_plato_id integer, p_cantidad_min integer) OWNER TO "estudiante";

--
-- Name: fn_obtener_pedidos_con_mesero(integer); Type: FUNCTION; Schema: public; Owner: estudiante
--

CREATE FUNCTION public.fn_obtener_pedidos_con_mesero(p_cliente_id integer) RETURNS TABLE(pedido_id integer, mesero_id integer, mesero_nombre text)
    LANGUAGE plpgsql
    AS $$
BEGIN
    -- Verificar que el cliente exista
    IF NOT EXISTS (SELECT 1 FROM usuarios WHERE id = p_cliente_id) THEN
        RAISE EXCEPTION 'El cliente con ID % no existe', p_cliente_id;
    END IF;

    RETURN QUERY
    SELECT PED.id AS pedido_id
         , PED.mesero_id
         , USR.nombre AS mesero_nombre
    FROM     pedidos AS PED
    JOIN     usuarios AS USR ON PED.mesero_id = USR.id
    WHERE    PED.cliente_id = p_cliente_id;
END;
$$;


ALTER FUNCTION public.fn_obtener_pedidos_con_mesero(p_cliente_id integer) OWNER TO "estudiante";

--
-- Name: fn_reporte_desempenho_meseros(timestamp without time zone, timestamp without time zone, integer, public.estadoorden, integer); Type: FUNCTION; Schema: public; Owner: estudiante
--

CREATE FUNCTION public.fn_reporte_desempenho_meseros(p_fecha_inicio timestamp without time zone, p_fecha_fin timestamp without time zone, p_tipo_plato_id integer, p_estado_orden public.estadoorden, p_min_platos_vendidos integer) RETURNS TABLE(nombre_mesero text, tipo_plato text, cantidad_total bigint, monto_total numeric, pedidos_atendidos bigint)
    LANGUAGE plpgsql
    AS $$
BEGIN
    -- Validar rango de fechas
    IF p_fecha_inicio >= p_fecha_fin THEN
        RAISE EXCEPTION 'La fecha de inicio no puede ser mayor o igual que la fecha final';
    END IF;
    
    -- Validar tipo de plato si se especificó
    IF p_tipo_plato_id IS NOT NULL AND NOT EXISTS (
        SELECT 1 FROM tipos AS TIP WHERE TIP.id = p_tipo_plato_id
    ) THEN
        RAISE EXCEPTION 'El tipo de plato con ID % no existe', p_tipo_plato_id;
    END IF;
    
    -- Validar cantidad mínima
    IF p_min_platos_vendidos <= 0 THEN
        RAISE EXCEPTION 'La cantidad mínima de platos debe ser mayor que cero';
    END IF;

    RETURN QUERY
    SELECT 
        USR.nombre AS nombre_mesero,
        TIP.nombre AS tipo_plato,
        SUM(ORD.cantidad) AS cantidad_total,
        SUM(ORD.cantidad * PLA.precio) AS monto_total,
        COUNT(DISTINCT PED.id) AS pedidos_atendidos
    FROM 
        pedidos AS PED
    JOIN 
        ordenes AS ORD ON PED.id = ORD.pedido_id
    JOIN 
        platos AS PLA ON ORD.plato_id = PLA.id
    JOIN 
        tipos AS TIP ON PLA.tipo_id = TIP.id
    JOIN 
        usuarios AS USR ON PED.mesero_id = USR.id
    JOIN 
        reservaciones AS RES ON PED.cliente_id = RES.cliente_id
    JOIN 
        horarios AS HOR ON RES.id = HOR.reservacion_id
    WHERE 
        PED.solicitado BETWEEN p_fecha_inicio AND p_fecha_fin
        AND ORD.estado = p_estado_orden
        AND (p_tipo_plato_id IS NULL OR PLA.tipo_id = p_tipo_plato_id)
    GROUP BY 
        USR.nombre, TIP.nombre
    HAVING 
        SUM(ORD.cantidad) >= p_min_platos_vendidos
    ORDER BY 
        monto_total DESC;
END;
$$;


ALTER FUNCTION public.fn_reporte_desempenho_meseros(p_fecha_inicio timestamp without time zone, p_fecha_fin timestamp without time zone, p_tipo_plato_id integer, p_estado_orden public.estadoorden, p_min_platos_vendidos integer) OWNER TO "estudiante";

--
-- Name: fn_reporte_ventas_tipos_plato(timestamp without time zone, timestamp without time zone); Type: FUNCTION; Schema: public; Owner: estudiante
--

CREATE FUNCTION public.fn_reporte_ventas_tipos_plato(p_fecha_inicio timestamp without time zone, p_fecha_fin timestamp without time zone) RETURNS TABLE(tipo_plato text, cantidad_vendida bigint, monto_total numeric, porcentaje_contribucion numeric)
    LANGUAGE plpgsql
    AS $$
DECLARE
    v_total_monto numeric;
BEGIN
    -- Calcular el monto total para el porcentaje
    SELECT COALESCE(SUM(ORD.cantidad * PLA.precio), 0) INTO v_total_monto
    FROM ordenes AS ORD
    JOIN platos AS PLA ON ORD.plato_id = PLA.id
    JOIN pedidos AS PED ON ORD.pedido_id = PED.id
    WHERE PED.solicitado BETWEEN p_fecha_inicio AND p_fecha_fin;

    RETURN QUERY
    SELECT 
        TIP.nombre AS tipo_plato,
        SUM(ORD.cantidad) AS cantidad_vendida,
        SUM(ORD.cantidad * PLA.precio) AS monto_total,
        CASE WHEN v_total_monto > 0 
             THEN ROUND(SUM(ORD.cantidad * PLA.precio) * 100.0 / v_total_monto, 2)
             ELSE 0 
        END AS porcentaje_contribucion
    FROM 
        tipos AS TIP
    JOIN 
        platos AS PLA ON TIP.id = PLA.tipo_id
    JOIN 
        ordenes AS ORD ON PLA.id = ORD.plato_id
    JOIN 
        pedidos AS PED ON ORD.pedido_id = PED.id
    WHERE 
        PED.solicitado BETWEEN p_fecha_inicio AND p_fecha_fin
    GROUP BY 
        TIP.nombre
    ORDER BY 
        monto_total DESC;
END;
$$;


ALTER FUNCTION public.fn_reporte_ventas_tipos_plato(p_fecha_inicio timestamp without time zone, p_fecha_fin timestamp without time zone) OWNER TO "estudiante";

--
-- Name: fn_validar_entregado(); Type: FUNCTION; Schema: public; Owner: estudiante
--

CREATE FUNCTION public.fn_validar_entregado() RETURNS trigger
    LANGUAGE plpgsql
    AS $$
DECLARE
    v_solicitado timestamp with time zone;
BEGIN
    -- Obtener la fecha de solicitud del pedido relacionado
    SELECT solicitado INTO v_solicitado
    FROM pedidos
    WHERE id = NEW.pedido_id;
    
    -- Validar que si hay fecha de entrega, sea posterior a la solicitud
    IF NEW.entregado IS NOT NULL AND v_solicitado IS NOT NULL AND NEW.entregado < v_solicitado THEN
        RAISE EXCEPTION 'La fecha de entrega (%) no puede ser anterior a la fecha de solicitud (%)', 
                        NEW.entregado, v_solicitado;
    END IF;
    
    RETURN NEW;
END;
$$;


ALTER FUNCTION public.fn_validar_entregado() OWNER TO "estudiante";

--
-- Name: fn_validar_fechas_pedido(); Type: FUNCTION; Schema: public; Owner: estudiante
--

CREATE FUNCTION public.fn_validar_fechas_pedido() RETURNS trigger
    LANGUAGE plpgsql
    AS $$
BEGIN
    -- Validar que la fecha de entrega no sea anterior a la de solicitud
    IF NEW.entregado IS NOT NULL AND 
       EXISTS (SELECT 1 FROM pedidos WHERE id = NEW.pedido_id AND solicitado > NEW.entregado) THEN
        RAISE EXCEPTION 'La fecha de entrega no puede ser anterior a la fecha de solicitud del pedido';
    END IF;
    
    RETURN NEW;
END;
$$;


ALTER FUNCTION public.fn_validar_fechas_pedido() OWNER TO "estudiante";

