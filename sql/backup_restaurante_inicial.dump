CREATE FUNCTION public.o(cliente integer) RETURNS TABLE(nom_mesero text, mesero_id integer, pedido integer)
    LANGUAGE plpgsql
    AS $$ begin
if not exists ( select 1 from Pedidos where cliente_id=cliente) 
then raise exception ' el usuario con id % no tiene pedidos asociados' , cliente ;
end if 
; 
return query
 select U.nombre ,U.id,P.id from Usuarios U 
LEFT join Pedidos P ON U.ID = P.MESERO_ID 
WHERE P.CLIENTE_ID=CLIENTE; 
END ;
$$;


