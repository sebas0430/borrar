--
-- Name: validar_cocinero(); Type: FUNCTION; Schema: public; Owner: estudiante
--

CREATE FUNCTION public.validar_cocinero() RETURNS trigger
    LANGUAGE plpgsql
    AS $$
BEGIN
    -- Verificar si el usuario tiene el rol de cocinero
    IF NOT EXISTS (
        SELECT 1
        FROM Actuaciones a
        JOIN Roles r ON a.rol_id = r.id
        WHERE a.usuario_id = NEW.cocinero_id AND r.nombre = 'cocinero'
    ) THEN
        RAISE EXCEPTION 'El usuario con id % no tiene el rol de cocinero.', NEW.cocinero_id;
    END IF;
    RETURN NEW;
END;
$$;


ALTER FUNCTION public.validar_cocinero() OWNER TO "estudiante";

--
-- Name: validar_mesero(); Type: FUNCTION; Schema: public; Owner: estudiante
--

CREATE FUNCTION public.validar_mesero() RETURNS trigger
    LANGUAGE plpgsql
    AS $$
BEGIN
    -- Verificar si el usuario tiene el rol de mesero
    IF NOT EXISTS (
        SELECT 1
        FROM Actuaciones a
        JOIN Roles r ON a.rol_id = r.id
        WHERE a.usuario_id = NEW.mesero_id AND r.nombre = 'mesero'
    ) THEN
        RAISE EXCEPTION 'El usuario con id % no tiene el rol de mesero.', NEW.mesero_id;
    END IF;
    RETURN NEW;
END;
$$;


ALTER FUNCTION public.validar_mesero() OWNER TO "estudiante";

